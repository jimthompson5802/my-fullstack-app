{
    "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
    "$id": "https://my-fullstack-app.example.com/patterns/fullstack-k8s.pattern.json",
    "title": "Full-Stack K8s Application Pattern",
    "description": "Pattern for full-stack calculator applications with React frontend, FastAPI backend, and Kubernetes deployment metadata",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "minItems": 2,
            "items": {
                "anyOf": [
                    {
                        "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                        "type": "object",
                        "properties": {
                            "node-type": {
                                "const": "service"
                            },
                            "metadata": {
                                "type": "object",
                                "properties": {
                                    "k8s": {
                                        "type": "object",
                                        "properties": {
                                            "image": {
                                                "type": "string"
                                            },
                                            "namespace": {
                                                "type": "string"
                                            },
                                            "replicas": {
                                                "type": "integer",
                                                "minimum": 1
                                            },
                                            "serviceName": {
                                                "type": "string"
                                            },
                                            "deploymentName": {
                                                "type": "string"
                                            },
                                            "appLabel": {
                                                "type": "string"
                                            },
                                            "containerPort": {
                                                "type": "integer",
                                                "minimum": 1,
                                                "maximum": 65535
                                            },
                                            "servicePort": {
                                                "type": "integer",
                                                "minimum": 1,
                                                "maximum": 65535
                                            },
                                            "nodePort": {
                                                "type": "integer",
                                                "minimum": 30000,
                                                "maximum": 32767
                                            },
                                            "imagePullPolicy": {
                                                "type": "string",
                                                "enum": ["Always", "IfNotPresent", "Never"]
                                            },
                                            "env": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "value": {
                                                            "type": "string"
                                                        }
                                                    },
                                                    "required": ["name", "value"]
                                                }
                                            },
                                            "livenessProbe": {
                                                "type": "object"
                                            },
                                            "readinessProbe": {
                                                "type": "object"
                                            }
                                        },
                                        "required": [
                                            "image",
                                            "namespace",
                                            "replicas",
                                            "serviceName",
                                            "deploymentName",
                                            "appLabel"
                                        ]
                                    }
                                },
                                "required": ["k8s"]
                            }
                        },
                        "required": ["metadata"]
                    },
                    {
                        "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node"
                    }
                ]
            }
        },
        "relationships": {
            "type": "array",
            "minItems": 1
        }
    },
    "required": ["nodes"]
}

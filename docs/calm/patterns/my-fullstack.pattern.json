{
    "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
    "$id": "https://my-fullstack-app.example.com/patterns/fullstack-k8s.pattern.json",
    "title": "Full-Stack K8s Application Pattern",
    "description": "Pattern for full-stack calculator applications with React frontend, FastAPI backend, and Kubernetes deployment metadata",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "minItems": 2,
            "items": {
                "anyOf": [
                    {
                        "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node",
                        "type": "object",
                        "properties": {
                            "node-type": {
                                "const": "service"
                            },
                            "metadata": {
                                "$ref": "https://my-fullstack-app.example.com/standards/k8s-service-metadata.json"
                            }
                        },
                        "required": ["metadata"]
                    },
                    {
                        "$ref": "https://calm.finos.org/release/1.2/meta/core.json#/defs/node"
                    }
                ]
            }
        },
        "relationships": {
            "type": "array",
            "minItems": 1
        }
    },
    "required": ["nodes"]
}
